# 搜索引擎配置（用于获取股票新闻）
# Tavily API Keys（支持多个，逗号分隔）
TAVILY_API_KEYS=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
# SerpAPI Keys（支持多个，逗号分隔）
SERPAPI_API_KEYS=ee15d7065b70f9b56182126173cd13fabe46cbf227394cf42d65f0e667c2aa79
# Brave Search API Keys（支持多个，逗号分隔）
# 获取: https://brave.com/search/api/
BRAVE_API_KEYS=BSAWbK1C9QBMnfLS3Jn0nD0M6Gbxpmc

# ===================================
# 新闻时效与分析筛选配置
# ===================================
# 新闻最大时效（天），搜索时限制结果在近期内，避免使用过时信息
NEWS_MAX_AGE_DAYS=5

# Stock API Key
ALPHA_VANTAGE_API_KEY=3BXKY6E8EHG06JO3


# 系统配置
# 日志目录
LOG_DIR=./logs
# 日志级别（DEBUG/INFO/WARNING/ERROR）
LOG_LEVEL=INFO
# 最大并发线程数（建议保持低并发防封禁）
MAX_WORKERS=5
# 是否启用调试日志
DEBUG=false

